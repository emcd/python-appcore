{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": 1800000,
    "BASH_MAX_TIMEOUT_MS": 1800000,
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": 1,
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": 1,
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": 1,
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": 1
  },
  "enabledMcpjsonServers": [
    "agentmux",
    "context7",
    "nb"
  ],
  "permissions": {
    "auto_allow": [
      "mcp__agentmux__list",
      "mcp__agentmux__look",
      "mcp__agentmux__send",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__nb__help",
      "mcp__nb__nb",
      "Bash(hatch run *)",
      "Bash(hatch --env develop run *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh browse *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh search issues *)",
      "Bash(gh status *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git cat-file *)",
      "Bash(git checkout *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git grep *)",
      "Bash(git log *)",
      "Bash(git ls-files)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git merge-base *)",
      "Bash(git range-diff *)",
      "Bash(git rebase *)",
      "Bash(git restore *)",
      "Bash(git rev-list *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git stash list *)",
      "Bash(git status *)",
      "Bash(git worktree list)",
      "Bash(git worktree list *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(npm run *)",
      "Bash(openspec *)",
      "Bash(ps *)",
      "Bash(pwd *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true
  }
}
